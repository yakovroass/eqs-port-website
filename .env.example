# Copy to .env and adjust. Do not commit .env.

# PostgreSQL (required). Local example — create DB first or use Neon / Supabase / RDS.
# Amplify Hosting: set DATABASE_URL in the console (same URL for build + runtime).
# Pooled Neon host (…-pooler…): Prisma appends pgbouncer=true in code if missing — required for stable writes.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# First admin user (used by: npm run db:seed and Amplify preBuild seed). Set both in Amplify env.
ADMIN_USERNAME="ADMIN"
ADMIN_PASSWORD="change_this_min_8_chars"

# Same env as production: npm run db:verify-admin — checks DB reachability + password vs stored hash.
